# ===========================================
# KmedTour Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# -------------------------------------------
# Supabase Configuration (Required)
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -------------------------------------------
# AI Provider API Keys (At least one required)
# -------------------------------------------
# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenRouter (Multi-provider)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL_MAIN=anthropic/claude-3.5-sonnet

# xAI (Optional)
XAI_API_KEY=your-xai-api-key

# -------------------------------------------
# Payment Processing (Stripe)
# -------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# -------------------------------------------
# Email Service (Resend)
# -------------------------------------------
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=noreply@kmedtour.com
FROM_NAME=KmedTour

# -------------------------------------------
# Messaging (WhatsApp - Optional)
# -------------------------------------------
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# -------------------------------------------
# Database & Caching (Optional - for docker-compose)
# -------------------------------------------
POSTGRES_PASSWORD=your-secure-postgres-password
REDIS_PASSWORD=your-secure-redis-password
REDIS_URL=redis://localhost:6379

# Upstash Redis (Required for production rate limiting on serverless)
# Create a free database at https://upstash.com → Redis → Create Database
# Copy the REST URL and REST Token from the database dashboard
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Upstash Redis (Required for production rate limiting)
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# -------------------------------------------
# Monitoring & Observability (Optional)
# -------------------------------------------
# Langfuse
LANGFUSE_SECRET=your-langfuse-secret-key
LANGFUSE_URL=http://localhost:3030
LANGFUSE_SALT=your-langfuse-salt

# Sentry (Error Tracking - Required for production monitoring)
# Setup: https://sentry.io → New Project → Next.js
# 1. Create project, copy DSN from Settings → Client Keys
# 2. Generate auth token from Settings → Auth Tokens (scope: project:releases, org:read)
# 3. Add SENTRY_ORG and SENTRY_PROJECT from your Sentry org slug and project slug
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=kmedtour-web

# -------------------------------------------
# Application Configuration
# -------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Rate Limiting
RAG_RATE_LIMIT=30

# Cron / internal job auth (e.g. notification processor)
CRON_SECRET=your-cron-secret-for-api-notifications-process

# Python Agent URL (for RAG/AI features)
PYTHON_AGENT_URL=http://127.0.0.1:8000

# -------------------------------------------
# Feature Flags (Optional)
# -------------------------------------------
ENABLE_AI_FEATURES=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_RAG_CHAT=true
